#!/bin/bash

ENV_MODE=${1:-stage}
ROOT_DIR=$(pwd)

if [ "$ENV_MODE" == "prod" ]; then
    COMPOSER_FLAGS="--no-dev --optimize-autoloader"
else
    COMPOSER_FLAGS="--optimize-autoloader"
fi

# ─── Root theme assets (wp-scripts via pnpm) ─────────────────────────────────
./bin/log "INFO" "Building root theme assets in $ENV_MODE mode..."
if [ "$ENV_MODE" == "prod" ]; then
    pnpm run build
else
    pnpm run build --mode=development
fi

# ─── Auto-discover plugins / themes with their own build script ──────────────
# Any directory under app/web/plugins/ or app/web/themes/ that contains a
# package.json with a "build" script will be built automatically.
BUILD_DIRS=(
    "app/web/plugins"
    "app/web/themes"
)

for BASE in "${BUILD_DIRS[@]}"; do
    if [ ! -d "$ROOT_DIR/$BASE" ]; then
        continue
    fi

    for PKG_FILE in "$ROOT_DIR/$BASE"/*/package.json; do
        DIR=$(dirname "$PKG_FILE")

        # Skip if there is no "build" script in package.json
        if ! grep -q '"build"' "$PKG_FILE" 2>/dev/null; then
            continue
        fi

        ./bin/log "INFO" "Building assets in $DIR using $ENV_MODE mode..."
        cd "$DIR" || exit

        if [ -f "pnpm-lock.yaml" ]; then
            pnpm install --frozen-lockfile
            pnpm run build
        elif [ -f "package-lock.json" ]; then
            npm ci
            npm run build
        else
            npm install
            npm run build
        fi

        cd "$ROOT_DIR" || exit
    done
done

# ─── Composer (app root) ─────────────────────────────────────────────────────
./bin/log "INFO" "Installing Composer dependencies ($ENV_MODE)..."
./bin/composer install $COMPOSER_FLAGS

# ─── Per-plugin Composer installs ────────────────────────────────────────────
# Add any plugin that ships its own composer.json here.
COMPOSER_PLUGIN_DIRS=()

for PLUGIN_COMPOSER in "${COMPOSER_PLUGIN_DIRS[@]}"; do
    if [ -f "/var/www/html/$PLUGIN_COMPOSER/composer.json" ]; then
        ./bin/log "INFO" "Installing Composer deps for $PLUGIN_COMPOSER..."
        ./bin/composer install -d "/var/www/html/$PLUGIN_COMPOSER" $COMPOSER_FLAGS
    fi
done

./bin/log "SUCCESS" "Build complete."
