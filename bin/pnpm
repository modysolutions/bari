#!/bin/bash
ROOT_DIR=$(pwd)
ENV_FILE="${ROOT_DIR}/.env"

if [ ! -f "${ENV_FILE}" ]; then
  ./bin/log "ERROR" "No .env file found. Please create one based on .env.example."
  exit 1;
fi

source "${ENV_FILE}";

PNPM=$(which pnpm)

if [ PNPM = "" ]; then
  ./bin/log "ERROR" "No pnpm installed"
  exit 1;
fi

./bin/log "INFO" "Executing pnpm command $*"
$PNPM -C "${ROOT_DIR}/app/wp-content" "$@"
