#!/bin/bash

ROOT_DIR=$(pwd)
ENV_FILE="${ROOT_DIR}/.env"
./bin/log "INFO" "Checking .env file exists in ${ENV_FILE}"
if [ ! -f "${ENV_FILE}" ]; then
  ./bin/log "ERROR" "No .env file found"
  exit 1;
fi
source "${ENV_FILE}";
TYPE=${1:-"single"}

./bin/certs
mkdir -p "${ROOT_DIR}/app/logs" && \
touch "${ROOT_DIR}/app/logs/xdebug.log" && \
touch "${ROOT_DIR}/app/logs/wp.log" && \
chmod 666 "${ROOT_DIR}/app/logs/xdebug.log" "${ROOT_DIR}/app/logs/wp.log" && \

./bin/config WORDPRESS_ALLOW_MULTISITE 0 && \
./bin/config WORDPRESS_MULTISITE 0 && \
./bin/config WORDPRESS_SUBDOMAIN_INSTALL 0 && \
docker compose up -d --build --force-recreate --remove-orphans

./bin/version "${WORDPRESS_VERSION}" --no-backup && \
./bin/composer config http-basic."${SATISPRESS_URL}" "${SATISPRESS_KEY}" "satispress" && \
./bin/composer install

if [ $? -eq 0 ]; then
    ./bin/log "INFO" "Infraestructura y Composer instalados con éxito. Evaluando tipo de instalación..."

    if [ "${TYPE}" == "multisite" ]; then
        ./bin/log "INFO" "Iniciando instalación en modo WordPress Multisite..."
        ./bin/wp core multisite-install \
            --url="${HOST_NAME}" \
            --title="${SITE_TITLE}" \
            --admin_user="${SITE_ADMIN}" \
            --admin_email="${SITE_ADMIN_EMAIL:-admin@${HOST_NAME}}" \
            --admin_password="${SITE_ADMIN_PASSWD}" \
            --skip-email
    else
        ./bin/log "INFO" "Ejecutando instalación estándar (Single Site)..."
        # Aquí puedes añadir el comando para instación single si lo deseas en el futuro
    fi
else
    ./bin/log "ERROR" "La instalación de dependencias o Docker falló. Abortando instalación de WordPress."
    exit 1
fi

./bin/log "SUCCESS" "Installation completed successfully"