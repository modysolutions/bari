#!/bin/bash

ROOT_DIR=$(pwd)
ENV_FILE="${ROOT_DIR}/.env"
./bin/log "INFO" "Checking .env file exists in ${ENV_FILE}"
if [ ! -f "${ENV_FILE}" ]; then
  ./bin/log "ERROR" "No .env file found"
  exit 1;
fi
source "${ENV_FILE}";

./bin/certs
docker compose up -d --build --force-recreate
./bin/version ${WORDPRESS_VERSION}
./bin/composer -d /var/www/html config http-basic.plugins.tamarindintelligence.com "${SATISPRESS_KEY}" "satispress"
./bin/wp core install --url="${SITE_HOST}" --title="${SITE_TITLE}" --admin_user="${SITE_ADMIN}" --admin_email="${SITE_ADMIN}" --admin_password="${SITE_ADMIN_PASSWD}" --skip-email
./bin/wp core multisite-convert --title="${SITE_TITLE}" --skip-config --subdomains
