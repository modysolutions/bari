#!/bin/bash

APP_DIR="./app"
TEMP_DIR="./wp_tmp"
BACKUP_DIR="./wp_core_backup_$(date +%Y%m%d_%H%M%S)"

show_help() {
    ./bin/log "ERROR" "Usage: ./wp-version [VERSION]"
    ./bin/log "INFO" "Example: ./wp-version.sh 6.2.2"
    ./bin/log "INFO" "This will download WordPress [VERSION] and update the $APP_DIR folder while keeping wp-content."
}

if [ -z "$1" ]; then
    show_help
    exit 1
fi

VERSION=$1
URL="https://wordpress.org/wordpress-$VERSION.tar.gz"

./bin/log "INFO" "--- Checking target directory ---"
if [ ! -d "$APP_DIR" ]; then
    ./bin/log "ERROR" "Directory $APP_DIR not found. Run this from your project root."
    exit 1
fi

./bin/log "INFO" "--- Downloading WordPress $VERSION ---"
mkdir -p "$TEMP_DIR"
curl -L "$URL" | tar -xz -C "$TEMP_DIR"

if [ $? -ne 0 ]; then
    ./bin/log "ERROR" "Failed to download or extract WordPress $VERSION. Check the version number."
    rm -rf "$TEMP_DIR"
    exit 1
fi

./bin/log "INFO" "--- Backing up current core files to $BACKUP_DIR ---"
mkdir -p "$BACKUP_DIR"
cp -r "$APP_DIR/wp-admin" "$APP_DIR/wp-includes" "$BACKUP_DIR/"
cp "$APP_DIR"/*.php "$BACKUP_DIR/"

./bin/log "INFO" "--- Replacing core files (excluding wp-content) ---"

rm -rf "$APP_DIR/wp-admin"
rm -rf "$APP_DIR/wp-includes"

mv "$TEMP_DIR/wordpress/wp-admin" "$APP_DIR/"
mv "$TEMP_DIR/wordpress/wp-includes" "$APP_DIR/"

cp "$TEMP_DIR/wordpress/"*.php "$APP_DIR/"

./bin/log "INFO" "--- Cleaning up ---"
rm -rf "$TEMP_DIR"

./bin/log "SUCCESS" "Successfully switched to WordPress $VERSION"
./bin/log "WARNING" "Note: Visit your site's /wp-admin/upgrade.php to update the database if prompted."