#!/bin/bash
ROOT_DIR=$(pwd)
ENV_FILE="${ROOT_DIR}/.env"

if [ ! -f $ENV_FILE ]; then
  ./bin/log "ERROR" "No .env file found"
  exit 1;
fi

./bin/log "INFO" "Generating SSL certificates for local development domains..."
if [ ! -d "$ROOT_DIR/config/ssl" ]; then
  mkdir -p "$ROOT_DIR/config/ssl"
fi

source "${ENV_FILE}"

./bin/log "INFO" "Running mkcert to generate certificates for local domains..."
mkcert -cert-file ./config/ssl/local-cert.pem -key-file ./config/ssl/local-key.pem "${APP_DOMAINS}" 127.0.0.1
sudo mkcert -install