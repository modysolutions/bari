#!/bin/bash
ROOT_DIR=$(pwd)

./bin/log "INFO" "Generating SSL certificates for local development domains..."
if [ ! -d "$ROOT_DIR/config/ssl" ]; then
  mkdir -p "$ROOT_DIR/config/ssl"
fi

./bin/log "INFO" "Running mkcert to generate certificates for local domains..."
mkcert -cert-file ./config/ssl/local-cert.pem -key-file ./config/ssl/local-key.pem "ecigintelligence.local" "*.ecigintelligence.local" "tobaccointelligence.local" "*.tobaccointelligence.local" "cannintelligence.local" "*.cannintelligence.local" "tamarindintelligence.local" "*.tamarindintelligence.local" 127.0.0.1
sudo mkcert -install