#!/bin/bash
ROOT_DIR=$(pwd)
YML_FILE="${ROOT_DIR}/wp-cli.yml"
ENV_FILE="${ROOT_DIR}/.env"

if [ ! -f $ENV_FILE ]; then
  ./bin/log "ERROR" "No .env file found"
  exit 1;
fi

source "${ENV_FILE}"
ALIAS="${SITE_SLUG}"

if [ ! -f "$YML_FILE" ]; then
    ./bin/log "ERROR" "wp-cli.yml not found in $(pwd)"
    exit 1
fi

CONTAINER_NAME=$(grep -A 1 "@$ALIAS:" "$YML_FILE" | grep 'ssh:' | sed -E 's/.*@([^ ]+).*/\1/')

if [ -z "$CONTAINER_NAME" ]; then
    ./bin/log "ERROR" "Alias @$ALIAS not found in $YML_FILE"
    exit 1
fi

if [ -t 0 ]; then
    TTY_FLAG="-it"
else
    TTY_FLAG="-i"
fi
./bin/log "INFO" "wp $* in container $CONTAINER_NAME"
docker exec $TTY_FLAG -u www-data "$CONTAINER_NAME" wp "$@"
