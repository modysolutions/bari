#!/bin/bash

ROOT_DIR=$(pwd)
ENV_FILE="${ROOT_DIR}/.env"

if [ ! -f "${ENV_FILE}" ]; then
  log_message "ERROR" "No .env file found."
  exit 1;
fi
source "${ENV_FILE}";

if [ -z "$1" ]; then
  ./bin/log "ERROR" "You need to provide a command (e.g., ./bin/composer install)"
  exit 1
fi
./bin/log "INFO" "Running composer command: $*"
EXEC_FLAGS=()
if [ -t 0 ] && [ -t 1 ]; then
  EXEC_FLAGS=(-it)
fi

docker exec "${EXEC_FLAGS[@]}" "${CONTAINER_PREFIX}app" /usr/local/bin/composer "$@" -d /var/www/html
