#!/bin/bash

TO=${1:-ei}
case "$TO" in
    "ei")
      SITE=ecigintelligence
      ;;
    "ti")
      SITE=tobaccointelligence
      ;;
    "ci")
      SITE=cannintelligence
      ;;
    "cti")
      SITE=tamarindintelligence
      ;;
    *)
      ./bin/log "ERROR" "Use ./bin/to ei|ti|ci|cti"
      exit
      ;;
  esac

./bin/log "INFO" "Switching to ${SITE} environment"
docker compose down

./bin/log "INFO" "Updating .env file with new environment variables"
bash bin/config SITE_NAME "$SITE"
bash bin/config SITE_SLUG "${TO}"
bash bin/config CONTAINER_PREFIX "${TO}_"
bash bin/config HOST_NAME "${SITE}.local"
bash bin/config PROXY_NAME "${SITE}.com"

./bin/log "INFO" "Starting Docker containers for ${SITE} environment"
docker compose up -d --remove-orphans
./bin/log "SUCCESS" "You can access the site on https://${SITE}.local"