DB_NAME=local
DB_USER=user
DB_PASSWORD=password
DB_ROOT_PASSWORD=rootpassword

WORDPRESS_ENVIRONMENT="local"
WORDPRESS_DEBUG=true
WORDPRESS_DEBUG_LOG=../logs/debug.log
WORDPRESS_DEBUG_DISPLAY=false
WORDPRESS_TABLE_PREFIX=wp_
WORDPRESS_VERSION=7.0
WORDPRESS_IMAGE_VERSION="${WORDPRESS_VERSION}-fpm-alpine"
WORDPRESS_MEMORY_LIMIT="256M"

WORDPRESS_SMTP_ON=true
WORDPRESS_SMTP_MAILER="smtp"
WORDPRESS_SMTP_HOST="mailpit"
WORDPRESS_SMTP_PORT=1025

# Production environment variables
WORDPRESS_DISALLOW_FILE_EDIT=true
WORDPRESS_AUTOMATIC_UPDATER_DISABLED=true
WORDPRESS_DISALLOW_FILE_MODS=false
WORDPRESS_AUTO_UPDATE_CORE=false
WORDPRESS_POST_REVISIONS=3
WORDPRESS_CONCATENATE_SCRIPTS=true
WORDPRESS_FORCE_SSL_ADMIN=true
WORDPRESS_EMPTY_TRASH_DAYS=3
WORDPRESS_COMPRESS_CSS=true
WORDPRESS_COMPRESS_SCRIPTS=true
WORDPRESS_ENFORCE_GZIP=true
WORDPRESS_DISABLE_WP_CRON=true

SITE_TITLE="Tamarind Intelligence Hub"
SITE_ADMIN="user@tamarindintelligence.com"
SITE_ADMIN_PASSWD="password"
SITE_NAME=auth.tamarindintelligence
HOST_NAME="${SITE_NAME}.local"
PROXY_NAME="${SITE_NAME}.com"

SITE_SLUG=tims
CONTAINER_PREFIX="${SITE_SLUG}_"

SSH_HOST_PRODUCTION=tamarindintelligence.com
SSH_HOST_STAGE=stage.tamarindintelligence.com

SATISPRESS_KEY=satispress-key-placeholder
