{% extends '@theme/layouts/base.twig' %}

{% block content %}
    {#
        Block-based page: post.content runs through do_blocks() automatically,
        so all Gutenberg blocks (core, ACF, Astra) render correctly.

        The .entry-content class enables WordPress's default block gap and
        alignment styles (.alignfull, .alignwide, .aligncenter).
    #}
    <article id="post-{{ post.id }}" class="{{ post.class }}">
        <div class="entry-content">
            {{ post.content }}
        </div>
    </article>
{% endblock %}
