<!DOCTYPE html>
<html {{ site.language_attributes }}>

    {% block head %}
        {% include '@theme/partials/head.twig' %}
    {% endblock %}

    <body class="{{ body_class }}">
        {{ function('wp_body_open') }}

        <a class="skip-link screen-reader-text" href="#main-content">
            {{- _e('Skip to content') -}}
        </a>

        {% block header %}
            <header class="site-header" role="banner">
                <div class="site-header__inner">
                    <div class="site-header__branding">
                        <a class="site-header__logo" href="{{ site.url }}" rel="home">
                            {{ site.name }}
                        </a>
                    </div>
                    <nav id="site-navigation" class="site-header__nav" role="navigation"
                         aria-label="{{ _e('Primary Navigation') }}">
                        {% include '@theme/partials/menu.twig' with {
                            items: header_menu ? header_menu.get_items : []
                        } %}
                    </nav>
                </div>
            </header>
        {% endblock %}

        {#
            #main-content wraps every block template. Blocks using alignfull or
            alignwide will break out of the inner max-width constraint via CSS.
            Do not add overflow:hidden or a max-width directly on this element.
        #}
        <main id="main-content" class="site-main" role="main" tabindex="-1">
            {% block content %}{% endblock %}
        </main>

        {% block footer %}
            {% include '@theme/partials/footer.twig' %}
        {% endblock %}

        {{ function('wp_footer') }}
        {% do action('get_footer') %}
    </body>
</html>
